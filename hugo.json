{
  "baseURL": "https://iancmd.dev/",
  "title": "ianiiaannn's Blog",
  "theme": "poison",
  "enableRobotsTXT": false,
  "timeZone": "Asia/Taipei",
  "enableGitInfo": true,
  "defaultContentLanguage": "zh",
  "defaultContentLanguageInSubdir": false,
  "enableEmoji": true,
  "languages": {
    "zh": {
      "weight": 1,
      "locale": "zh-Hant-TW",
      "label": "繁體中文",
      "hasCJKLanguage": true
    },
    "en": {
      "weight": 2,
      "locale": "en-US",
      "label": "English",
      "hasCJKLanguage": false
    }
  },
  "markup": {
    "safeMode": true,
    "highlight": {
      "tabWidth": 2,
      "style": "onedark",
      "lineNos": false,
      "guessSyntax": true
    },
    "tableOfContents": {
      "startLevel": 2,
      "endLevel": 4,
      "ordered": false
    },
    "goldmark": {
      "extensions": {
        "cjk": {
          "eastAsianLineBreaks": true,
          "eastAsianLineBreaksStyle": "simple",
          "enable": true
        },
        "extras": {
          "subscript": {
            "enable": true
          },
          "superscript": {
            "enable": true
          },
          "delete": {
            "enable": true
          }
        },
        "strikethrough": false
      }
    }
  },
  "frontmatter": {
    "lastmod": [
      ":git"
    ],
    "publishDate": [
      "date",
      "Date"
    ],
    "date": [
      "date",
      "Date"
    ]
  },
  "security": {
    "allowContent": [
      ".*"
    ]
  },
  "params": {
    "brand": "ianiiaannn's Blog",
    "brand_image": "/profile.webp",
    "dark_mode": true,
    "gtag": "G-QSNCX5Z8MF",
    "adsense": "ca-pub-3156472131130250",
    "github": "ianiiaannn",
    "github_url": "https://github.com/ianiiaannn",
    "summaryLength": 127
  }
}